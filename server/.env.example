# PostgreSQL connection string from Cloud SQL
# Format: postgresql://USER:PASSWORD@HOST:5432/DB_NAME
# For Cloud Run connecting to Cloud SQL via socket:
# postgresql://USER:PASSWORD@localhost/DB_NAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
DATABASE_URL="postgresql://postgres:password@localhost:5432/anphonic_shop"

# Generate a strong secret: openssl rand -base64 64
JWT_SECRET="replace-with-a-long-random-secret"

# Comma-separated list of allowed frontend origins
# Production: use only the real production domain(s), drop localhost entries
ALLOWED_ORIGINS="https://shop.anphonic.ai"

# Port (Cloud Run sets this automatically to 8080)
PORT=3001

# Production: set to "production" — this enables stricter defaults (e.g. secure cookies, less verbose errors)
NODE_ENV=production
