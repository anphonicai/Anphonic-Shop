generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  phone      String
  ageGroup   String
  gender     String
  city       String
  country    String
  categories String[]
  consent    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([email])
}

model BrandSubmission {
  id           String   @id @default(cuid())
  brandName    String
  website      String
  contactName  String
  contactEmail String
  contactPhone String?
  category     String
  description  String
  offerDetails String
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  @@index([contactEmail])
}
